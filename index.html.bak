    <button class="mobile-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- ============ PAGE 1: HOMEPAGE ============ -->

<!-- HERO SECTION -->
<section class="hero" id="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        <span data-i18n="hero-eyebrow">Powered by The Performa Group · 20-Year Security Legacy</span>
      </div>
      <h1 data-i18n="hero-title">AI Copilot for <span class="text-red">Government Budget Leaders</span>.</h1>
      <p class="hero-sub" data-i18n="hero-sub">Cut weeks of manual budget analysis down to seconds. Scotty leverages generative AI to forecast, scenario-plan, and optimize public funds—backed by the 20-year security legacy of The Performa Group.</p>
      <div class="hero-ctas">
        <a href="#" class="btn btn-red btn-lg" data-i18n="nav-try">Try Scotty For Free</a>
        <a href="#" class="btn-link">
          <span class="play-btn">
            <svg width="10" height="12" viewBox="0 0 10 12"><polygon points="1,1 9,6 1,11" fill="#BE2332"/></svg>
          </span>
          <span data-i18n="hero-watch">Watch the 60s Executive Briefing</span>
        </a>
      </div>
      <div class="hero-social-proof">
        <div class="proof-avatars">
          <div class="proof-avatar" style="background:var(--slate-200);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700">TX</div>
          <div class="proof-avatar" style="background:#BE2332;"></div>
          <div class="proof-avatar" style="background:#334155;"></div>
        </div>
        <span data-i18n="hero-trusted">Trusted by <strong>50+</strong> state &amp; federal agencies</span>
      </div>
    </div>

    <div class="hero-visual">
      <div class="dashboard-mock">
        <div class="mock-topbar">
          <span class="mock-dot red"></span>
          <span class="mock-dot yellow"></span>
          <span class="mock-dot green"></span>
          <span class="mock-title">Scotty AI — Budget Intelligence</span>
          <span class="mock-live-badge">● LIVE</span>
        </div>
        <div class="mock-body">

          <!-- Search Hook — The Star of the Show -->
          <div class="mock-search-wrapper">
            <p class="mock-search-label">
              <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3.5" fill="#BE2332"/></svg>
              Enter your District or Agency to see your 20% public data insights instantly.
            </p>
            <div class="mock-search">
              <input type="text" id="agency-search" placeholder='e.g., "Texas DOT" or "District 14"' autocomplete="off">
              <button class="btn btn-red btn-sm" id="scan-btn">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><circle cx="4.5" cy="4.5" r="3.5" stroke="white" stroke-width="1.4"/><path d="M7.5 7.5l2.2 2.2" stroke="white" stroke-width="1.4" stroke-linecap="round"/></svg>
                Analyze
              </button>
            </div>
            <div class="mock-suggestions">
              <button class="suggestion-chip" data-query="Texas DOT">Texas DOT</button>
              <button class="suggestion-chip" data-query="CA Legislature">CA Legislature</button>
              <button class="suggestion-chip" data-query="FHWA District 4">FHWA District 4</button>
            </div>
          </div>

          <!-- Results Area (scan overlay + data) -->
          <div class="mock-results-area" id="mock-results-area">

            <!-- AI Scanning Overlay -->
            <div class="scan-overlay" id="scan-overlay">
              <div class="scan-header">
                <div class="scan-pulse-wrapper">
                  <div class="scan-pulse-ring"></div>
                  <div class="scan-pulse-ring delay"></div>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="#BE2332" stroke-width="1.5"/><path d="M4.5 7l2 2 3.5-3.5" stroke="#BE2332" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div class="scan-title-group">
                  <span class="scan-label">Scotty AI Analyzing</span>
                  <strong class="scan-agency-name" id="scan-agency-name">Texas DOT</strong>
                </div>
              </div>

              <div class="scan-line-track">
                <div class="scan-line" id="scan-line"></div>
              </div>

              <div class="scan-steps" id="scan-steps">
                <div class="scan-step" id="scan-step-0">
                  <span class="step-dot"></span>
                  <span class="step-text">Aggregating public budget records</span>
                  <span class="step-check">✓</span>
                </div>
                <div class="scan-step" id="scan-step-1">
                  <span class="step-dot"></span>
                  <span class="step-text">Cross-referencing BIDS database</span>
                  <span class="step-check">✓</span>
                </div>
                <div class="scan-step" id="scan-step-2">
                  <span class="step-dot"></span>
                  <span class="step-text">Running AI variance analysis</span>
                  <span class="step-check">✓</span>
                </div>
                <div class="scan-step" id="scan-step-3">
                  <span class="step-dot"></span>
                  <span class="step-text">Generating 20% public insights</span>
                  <span class="step-check">✓</span>
                </div>
              </div>

              <div class="scan-progress-track">
                <div class="scan-progress-fill" id="scan-progress-fill"></div>
              </div>

              <div class="scan-stats">
                <div class="scan-stat">
                  <span class="scan-stat-num" id="stat-records">0</span>
                  <span class="scan-stat-label">Records</span>
                </div>
                <div class="scan-stat">
                  <span class="scan-stat-num" id="stat-lines">0</span>
                  <span class="scan-stat-label">Budget Lines</span>
                </div>
                <div class="scan-stat">
                  <span class="scan-stat-num" id="stat-variance">0</span>
                  <span class="scan-stat-label">Variances</span>
                </div>
              </div>
            </div>

            <!-- Data Results -->
            <div class="mock-results" id="mock-results">
              <div class="results-complete-badge" id="results-badge">
                <svg width="9" height="9" viewBox="0 0 9 9"><circle cx="4.5" cy="4.5" r="4" fill="#34d399"/></svg>
                Analysis complete — <span id="results-agency">Texas DOT</span>
              </div>
              <div class="mock-charts">
                <div class="mock-chart">
                  <div class="bar-group">
                    <div class="bar" style="--h:58%"></div>
                    <div class="bar" style="--h:82%"></div>
                    <div class="bar" style="--h:47%"></div>
                    <div class="bar accent" style="--h:94%"></div>
                    <div class="bar" style="--h:61%"></div>
                    <div class="bar" style="--h:73%"></div>
                  </div>
                  <span class="chart-label">Budget Allocation FY26</span>
                </div>
                <div class="mock-chart">
                  <svg class="line-chart" viewBox="0 0 200 70" preserveAspectRatio="none">
                    <defs>
                      <linearGradient id="lineGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#BE2332" stop-opacity=".3"/>
                        <stop offset="100%" stop-color="#BE2332" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    <path d="M0,55 C30,50 30,42 60,48 S90,28 120,32 S150,14 200,18" fill="none" stroke="#BE2332" stroke-width="2.5" stroke-linecap="round"/>
                    <path d="M0,55 C30,50 30,42 60,48 S90,28 120,32 S150,14 200,18 L200,70 L0,70 Z" fill="url(#lineGrad)"/>
                    <path d="M0,62 C30,58 60,56 90,50 S150,44 200,40" fill="none" stroke="#BE2332" stroke-width="1.5" stroke-dasharray="5,3"/>
                  </svg>
                  <span class="chart-label">3-Year Trend</span>
                </div>
              </div>
              <div class="mock-table">
                <div class="table-row header"><span>Agency</span><span>FY 2026</span><span>Δ YoY</span></div>
                <div class="table-row"><span>TX DOT</span><span>$4.2B</span><span class="positive">+3.1%</span></div>
                <div class="table-row"><span>CA DOT</span><span>$6.8B</span><span class="positive">+1.7%</span></div>
                <div class="table-row"><span>FL DOT</span><span>$2.9B</span><span class="negative">−0.4%</span></div>
              </div>
            </div>
          </div><!-- /mock-results-area -->

        </div><!-- /mock-body -->
        <p class="mock-caption">
          <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3.5" fill="#BE2332" opacity=".6"/></svg>
          Public data insights · 20% view · Powered by Scotty AI
        </p>
      </div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<section class="trust-bar">
  <div class="container">
    <p class="trust-headline">Proven in Secure Environments</p>
    <div class="trust-logos">
      <div class="trust-logo-item">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="#BE2332" opacity=".1"/><circle cx="24" cy="16" r="5" stroke="#BE2332" stroke-width="2" fill="none"/><path d="M14 36c0-6 4-10 10-10s10 4 10 10" stroke="#BE2332" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
        <span>Federal Agency</span>
      </div>
      <div class="trust-logo-item">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="#BE2332" opacity=".1"/><path d="M12 36h24l-5-12H17z" stroke="#BE2332" stroke-width="2" fill="none" stroke-linejoin="round"/><path d="M20 24V14h8v10" stroke="#BE2332" stroke-width="2" fill="none" stroke-linejoin="round"/></svg>
        <span>State DOT</span>
      </div>
      <div class="trust-logo-item">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="#BE2332" opacity=".1"/><text x="24" y="28" font-size="13" fill="#BE2332" font-weight="800" text-anchor="middle">BIDS</text></svg>
        <span>BIDS Platform</span>
      </div>
      <div class="trust-logo-item">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="#BE2332" opacity=".1"/><path d="M24 8l12 8v12c0 6-12 12-12 12S12 34 12 28V16z" stroke="#BE2332" stroke-width="2" fill="none" stroke-linejoin="round"/><text x="24" y="30" font-size="10" fill="#BE2332" font-weight="800" text-anchor="middle">20Y</text></svg>
        <span>20 Years Security</span>
      </div>
      <div class="trust-logo-item">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="#BE2332" opacity=".1"/><circle cx="24" cy="24" r="12" stroke="#BE2332" stroke-width="2" fill="none"/><path d="M18 24l4 4 8-8" stroke="#BE2332" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>FedRAMP / NIST</span>
      </div>
    </div>
  </div>
</section>

<!-- FEATURE GRID -->
<section class="features" id="features">
  <div class="container">
    <h2 class="section-headline">Built for the Complexity of Public Finance.</h2>
    <div class="feature-cards">
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="#BE2332" opacity=".1"/><path d="M14 36l5-7 5 4 5-9 5 5" stroke="#BE2332" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 22h4l3-5 4 9 3-6 4 2h6" stroke="#BE2332" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity=".5"/></svg>
        </div>
        <h3>Priority-Driven Budgeting</h3>
        <p>Align every dollar with legislative goals. Use AI to rank expenditures by impact and necessity—ensuring your agency's budget reflects its highest priorities.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="#BE2332" opacity=".1"/><circle cx="24" cy="28" r="8" stroke="#BE2332" stroke-width="2" fill="none"/><path d="M24 20v-6M20 22l-4-4M28 22l4-4" stroke="#BE2332" stroke-width="2" stroke-linecap="round"/><circle cx="24" cy="28" r="2" fill="#BE2332"/></svg>
        </div>
        <h3>Automated Variance Detection</h3>
        <p>Identify budget anomalies and potential deficits months before they appear in traditional reports. Stay ahead of fiscal risk before it becomes a crisis.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="#BE2332" opacity=".1"/><rect x="14" y="20" width="6" height="12" rx="2" fill="#BE2332" opacity=".4"/><rect x="22" y="15" width="6" height="17" rx="2" fill="#BE2332" opacity=".7"/><rect x="30" y="10" width="6" height="22" rx="2" fill="#BE2332"/><path d="M11 36h28" stroke="#BE2332" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <h3>Legislative Scenario Testing</h3>
        <p>Instantly model the long-term impact of proposed funding shifts or policy changes on your specific agency. Answer "what if" before the vote, not after.</p>
      </div>
    </div>
  </div>
</section>


<!-- ============ STATS COUNTERS ============ -->
<section class="stats-counter" aria-label="Platform statistics">
  <div class="container">
    <div class="counters-grid">
      <div class="counter-item"><div class="counter-num" data-count="20" data-suffix="+">20+</div><div class="counter-label">Years of Government Experience</div></div>
      <div class="counter-item"><div class="counter-num" data-count="500" data-prefix="$" data-suffix="B+">$500B+</div><div class="counter-label">Budget Data Analyzed</div></div>
      <div class="counter-item"><div class="counter-num" data-count="99.99" data-suffix="%">99.99%</div><div class="counter-label">Platform Uptime</div></div>
      <div class="counter-item"><div class="counter-num" data-count="50" data-suffix="+">50+</div><div class="counter-label">Government Agencies Served</div></div>
    </div>
  </div>
</section>

<!-- THE HOOK — 20/80 SPLIT -->
<section class="hook-split" id="hook">
  <div class="container">
    <div class="split-intro">
      <h2>Start Free. See Everything When You're Ready.</h2>
      <p>Public data tells part of the story. Scotty tells the whole one.</p>
    </div>
    <div class="split-grid">
      <div class="split-side blurred-side">
        <div class="split-meta-tag fragmented">Public Data · 20%</div>
        <h3>Your Free Starting Point.</h3>
