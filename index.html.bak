<!-- ============ SITE HEADER ============ -->
<header class="site-header" id="site-header">
  <div class="header-inner">
    <div class="logo" style="display:flex; align-items:center; gap: 12px; text-decoration:none; color:inherit;">
      <a href="index.html" style="display:flex; align-items:center; color:inherit; text-decoration:none;" aria-label="Scotty AI Home">
      <svg class="logo-icon" viewBox="0 0 512 512" width="40" height="40"><style>.st1{fill:#BE2332;}</style><g><defs><rect id="s1" x="101" y="376.5" width="234.1" height="120.7"/></defs><clipPath id="c1"><use xlink:href="#s1"/></clipPath><g clip-path="url(#c1)"><path class="st1" d="M319.6,475c-20.9,17.1-52.2,13.4-52.2,13.4c40.4-6.2,44.1-20.2,44.5-22.9c3.8-31.1-75.7-48.4-121.3-39.2c-8.9,1.8-16.4,4.5-21.9,8.4c-30.7,21.7,18.6,54.7,65.8,62.4c0,0-47.4-.6-99.1-37.2c-16.8-11.9-31.3-26.5-33.7-41.6c-3.7-22.8,22.5-35.9,58.4-40.1c45.7-5.3,107.1,3.8,142.9,26.2C341.6,428.6,342.5,456.4,319.6,475"/></g></g><path class="st1" d="M392.2,438.5c53.5-72.3-56.4-118.1-138.3-130c-44.8-6.5-85.3-4.7-117.2,3.1C74,326.8,43.9,365.1,77.1,409c0,0-41.8-31.9-43.8-88.6c-1.8-52.9,63.8-68.1,98.9-72.5c1.5-.2,2.9-.3,4.2-.5c106.1-11.4,222.1,27.5,270.9,81.8C458.7,386.3,393.6,436.9,392.2,438.5"/><path class="st1" d="M477.3,333.8c.9-16.1,2.4-46.1-26.3-79.7c-56.8-66.3-197.1-97.8-301.6-82.7c-69.1,10-122.5,40.5-125.8,94.8c0,0-13.8-82.1,42.3-120.5c28.5-19.5,68.9-29.6,113.5-31c91.6-2.9,200.7,30.5,260.2,92.2C503.6,273.5,477.3,333.8,477.3,333.8"/><path class="st1" d="M497.8,201.3C456.1,103.2,331.1,60.4,223.9,64c-64.6,2.2-122.7,21.2-152.1,55.1l.1-.1c0,0,17.6-44.9,90.2-70.5c27.4-9.7,60.8-13.2,96-10.7c61.3,4.4,127.9,27.5,177,69.5C494.6,158,497.8,201.3,497.8,201.3"/><path class="st1" d="M428,76.8C397.7,57.1,359.8,41.3,317.2,32c-12.9-2.8-25.7-4.9-38.2-6.3c-28.9-3.2-56.6-2.8-81.8.8c31.5-10.5,66.2-14.3,101.6-9.8c7,.9,14.1,2.1,21.1,3.6C362.6,29.5,399.5,49.7,428,76.8"/><path class="st1" d="M77.1,409c0,0-41.8-31.9-43.8-88.6c-1.8-52.9,63.8-68.1,98.9-72.5c-1.3,20.8,0,42.1,4.3,63.6C74,326.8,43.9,365.1,77.1,409"/><path class="st1" d="M23.5,266.2c0,0-13.8-82.1,42.3-120.5c28.5-19.5,68.9-29.6,113.5-31c-12,17.5-22.2,36.5-30,56.7C80.2,181.5,26.8,211.9,23.5,266.2"/><g><defs><rect id="s2" x="101" y="377.7" width="134.1" height="119.5"/></defs><clipPath id="c2"><use xlink:href="#s2"/></clipPath><g clip-path="url(#c2)"><path class="st1" d="M234.4,497.1c0,0-47.4-.6-99.1-37.2c-16.8-11.9-31.3-26.5-33.7-41.6c-3.7-22.8,22.5-35.9,58.4-40.1c8.2,16.1,18.3,32.2,30.5,48.1c-8.9,1.8-16.4,4.5-21.9,8.4C138,456.3,187.3,489.4,234.4,497.1"/></g></g><path class="st1" d="M258.1,37.8c-11.9,7.7-23.4,16.4-34.2,26.2c-64.6,2.2-122.7,21.2-152.1,55.1l.1-.1c0,0,17.6-44.9,90.2-70.5C189.6,38.8,223,35.3,258.1,37.8"/><path class="st1" d="M298.8,16.6c-6.7,2.7-13.3,5.7-19.8,9.1c-28.9-3.2-56.6-2.8-81.8.8C228.8,16,263.5,12.2,298.8,16.6"/></svg>
      </a>
      <div style="display:flex; flex-direction:column; align-items:flex-start; justify-content:center;">
        <a href="index.html" style="color:inherit; text-decoration:none;"><span class="logo-text" style="line-height:0.85; font-size:1.6rem;">Scotty AI</span></a>
        <a href="https://theperformagroup.com/" target="_blank" style="font-size:10px;font-weight:500;color:#ffffff;letter-spacing:.04em;margin-top:-3px;display:inline-flex;align-items:center;text-decoration:none;"><span class="by-branding-text" style="transform:translateY(-1px); color:#ffffff;">By</span> <img src="performa-logo.png" alt="Performa" class="performa-logo-header" style="height:10px; margin-left:4px; margin-right:0; filter:none;"></a>
      </div>
    </div>
    <nav class="main-nav" id="main-nav">
      <a href="index.html" class="nav-link" style="color:var(--red);font-weight:700;">Home</a>
      <a href="about.html" class="nav-link">About Us</a>
      <a href="blog/index.html" class="nav-link">Blog</a>
      <a href="contact.html" class="nav-link">Contact</a>
    </nav>
    <div class="header-ctas">
            <div class="lang-switcher">
        <button class="lang-btn active" data-lang="en" aria-label="English">🇺🇸</button>
        <button class="lang-btn" data-lang="es" aria-label="Español">🇪🇸</button>
        <button class="lang-btn" data-lang="ja" aria-label="日本語">🇯🇵</button>
        <button class="lang-btn" data-lang="fr" aria-label="Français">🇫🇷</button>
      </div>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <a href="#" class="btn btn-outline-light" data-i18n="nav-login">Login</a>
